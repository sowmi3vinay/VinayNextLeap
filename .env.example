# Environment Variables for Zomato Restaurant Recommendation

# Required for LLM recommendations
GROQ_API_KEY=your_groq_api_key_here

# Optional: Hugging Face token for higher rate limits
HF_TOKEN=your_huggingface_token_here

# CORS configuration for local development and deployed frontend
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
VERCEL_ORIGIN_REGEX=https://.*\.vercel\.app

# For frontend deployment
API_URL=https://your-backend-domain
