# Environment Variables for Zomato Restaurant Recommendation

# Required for LLM recommendations
GROQ_API_KEY=your_groq_api_key_here

# Optional: Hugging Face token for higher rate limits
HF_TOKEN=your_huggingface_token_here

# CORS configuration for deployment (comma-separated URLs)
# Default allows localhost and Vercel domains
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://*.vercel.app

# For frontend build (Vercel)
API_URL=https://your-streamlit-app.streamlit.app
